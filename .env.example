# Copy this file to .env and fill in real values before running locally.
# Never commit the real .env file.

# Gold & Silver — pick ONE provider (GoldAPI is used first if both are set)
GOLDAPI_KEY=PASTE_YOUR_API_KEY_HERE
METALPRICEAPI_KEY=PASTE_YOUR_API_KEY_HERE

# USD/INR — Frankfurter is free and requires NO key. Nothing to set here.

# SENSEX / NIFTY 50 / BANK NIFTY — paid NSE/BSE data provider.
# Until this is set, placeholder data is served (see server/services/indices.js).
NSE_API_KEY=PASTE_YOUR_API_KEY_HERE

# Local dev port (optional, defaults to 8888)
PORT=8888
